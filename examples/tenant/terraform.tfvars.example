# TENANT stack — one per tenant. The project_id, network_id, policy_id and
# backup_target_id come from the admin stack outputs:
#   cd ../admin && terraform output            # policy_id, backup_target_id
#   cd ../admin && terraform output -json tenants   # project_id, network_id per tenant

auth_url          = "http://KEYSTONE_HOST:5000"
tenant_username   = "demo-tenant-a-user"
tenant_password   = "Demo1234!"               # per-project user password set by the admin scaffold
tenant_project_id = "paste-tenant-project-uuid"
network_id        = "paste-tenant-network-uuid"

policy_id        = "paste-policy_id-from-admin-output"
backup_target_id = "paste-backup_target_id-from-admin-output"

workload_name = "tenant-a-workload"
image_name    = "cirros-0.6.2"
flavor_name   = "m1.tiny"
